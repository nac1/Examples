Prefix(:=<http://example.org/norms#>)
Prefix(ifc:=<http://ifcowl.org/IFC2X3_TC1#>)
Prefix(owl:=<http://www.w3.org/2002/07/owl#>)
Prefix(rdf:=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>)
Prefix(xml:=<http://www.w3.org/XML/1998/namespace>)
Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)
Prefix(props:=<http://example.org/props#>)


Ontology(<http://example.org/norms/longbridge-example2-corrected>

Declaration(Class(:Bridge))
Declaration(Class(:LongBridge))
Declaration(Class(:LongBridgeCore))
Declaration(Class(:LongBridgeSupport))
Declaration(Class(ifc:IfcElement))
Declaration(DataProperty(props:length_simple_property))
Declaration(Datatype(:MinCoreLength_490))
Declaration(Datatype(:MinSupportLength_215))

############################
#   Data Properties
############################

# Data Property: props:length_simple_property (props:length_simple_property)

FunctionalDataProperty(props:length_simple_property)
DataPropertyRange(props:length_simple_property xsd:decimal)


############################
#   Datatypes
############################

# Datatype: :MinCoreLength_490 (:MinCoreLength_490)

DatatypeDefinition(:MinCoreLength_490 DatatypeRestriction(xsd:decimal xsd:minInclusive "490.0"^^xsd:decimal))

# Datatype: :MinSupportLength_215 (:MinSupportLength_215)

DatatypeDefinition(:MinSupportLength_215 DatatypeRestriction(xsd:decimal xsd:minExclusive "215.0"^^xsd:decimal))


############################
#   Classes
############################

# Class: :Bridge (Bridge)

AnnotationAssertion(rdfs:label :Bridge "Bridge"@en)
SubClassOf(:Bridge ifc:IfcElement)

# Class: :LongBridge (:LongBridge)

EquivalentClasses(:LongBridge ObjectUnionOf(:LongBridgeCore :LongBridgeSupport))

# Class: :LongBridgeCore (:LongBridgeCore)

EquivalentClasses(:LongBridgeCore ObjectIntersectionOf(:Bridge DataSomeValuesFrom(props:length_simple_property :MinCoreLength_490)))

# Class: :LongBridgeSupport (:LongBridgeSupport)

EquivalentClasses(:LongBridgeSupport ObjectIntersectionOf(:Bridge DataSomeValuesFrom(props:length_simple_property :MinSupportLength_215)))


)